#!/bin/bash

limit=5242880  # 5MB in bytes

while IFS= read -r -d '' file; do
    size=$(git cat-file -s ":$file" 2>/dev/null)
    if [ "$size" -gt "$limit" ]; then
        echo "ERROR: $file is $(( size / 1048576 ))MB, exceeds 5MB limit"
        exit 1
    fi
done < <(git diff --cached --name-only -z)
